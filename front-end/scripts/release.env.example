# Copy this file to `release.env` (same directory) and fill in real values.
# `release.env` is gitignored — never commit it.
#
# Both build-mac.sh and notarize-mac-installers.sh load release.env
# automatically, so once it exists you can just run:
#   pnpm build:mac        # build + sign
#   pnpm notarize:mac     # notarize + staple
#
# Keep the actual .p12 / .p8 files OUTSIDE the repo (e.g. ~/.certs/) and point
# the variables at them by absolute path.

# --- Code signing (used by build:mac) ---------------------------------------

# Developer ID Application cert — signs the .app, .dmg and .zip.
CSC_LINK=/Users/you/.certs/developer-id-application.p12
CSC_KEY_PASSWORD=your-application-cert-password

# Developer ID Installer cert — signs the .pkg.
CSC_INSTALLER_LINK=/Users/you/.certs/developer-id-installer.p12
CSC_INSTALLER_KEY_PASSWORD=your-installer-cert-password

# --- Notarization (used by notarize:mac) ------------------------------------

# Absolute path to your App Store Connect API key file.
APPLE_API_KEY=/Users/you/.certs/AuthKey_XXXXXXXXXX.p8

# The Key ID (the XXXXXXXXXX in the .p8 filename).
APPLE_API_KEY_ID=XXXXXXXXXX

# The Issuer ID (UUID shown at the top of the Team Keys page).
APPLE_API_ISSUER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
