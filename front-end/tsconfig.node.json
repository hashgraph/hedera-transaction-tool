{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "vite.config.*",

    "src/main/**/*",
    "src/preload/**/*",
    "src/tests/main/**/*",

    "src/shared/**/*",

    "../shared/src/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["vitest/globals"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/main/*"],
      "@shared/*": ["src/shared/*"]
    }
  }
}
